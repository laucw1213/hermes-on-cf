# Hermes-on-CF deploy environment — schema/template.
#
# Copy this file to `.env` (chmod 600), then APPEND real KEY=value lines below
# as you collect each value during the deploy. These commented keys are
# documentation only — they stay commented so `source .env` ignores them until
# a real line is appended.
#
# This file lives OUTSIDE hermes-cf on purpose (hermes-cf is the Docker build
# context, so a real `.env` here would never be shipped to Cloudflare).
#
# Hermes has NO gateway token and NO web dashboard: the AIG auth token (AIG_TOKEN)
# doubles as OPENAI_API_KEY; pairing is Telegram-only.
#
# ── Non-secret (safe to echo in status) ──
# NAME=                  # bot name, lowercased; worker = hermes-<NAME>
# ACCOUNT_ID=            # Cloudflare account id (32 hex)
# CLOUDFLARE_ACCOUNT_ID= # = ACCOUNT_ID (pins wrangler to the account)
# SUBDOMAIN=             # your <subdomain>.workers.dev
# BOT_USERNAME=          # Telegram bot @username (from getMe, Step 11)
#
# ── Secret (never echo a value) ──
# CLOUDFLARE_API_TOKEN=  # CF API token              (Step 1)
# AIG_TOKEN=             # AI Gateway auth token (= OPENAI_API_KEY)  (Step 2)
# R2_ACCESS_KEY=         # R2 access key id          (Step 3)
# R2_SECRET_KEY=         # R2 secret access key      (Step 3)
# TELEGRAM_TOKEN=        # Telegram bot token        (Step 4)
